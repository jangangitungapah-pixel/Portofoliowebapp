@page "/studio-demo"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Studio Music Management Demo</PageTitle>

<main class="studio-demo-page">
    <AppToast Visible="IsToastVisible"
              Title="@ToastTitle"
              Message="@ToastMessage"
              Type="@ToastType"
              OnClose="HideToast" />

    <ConfirmDialog Visible="IsConfirmVisible"
                   Eyebrow="@ConfirmEyebrow"
                   Title="@ConfirmTitle"
                   Message="@ConfirmMessage"
                   ButtonText="@ConfirmButtonText"
                   Icon="@ConfirmIcon"
                   Type="@ConfirmType"
                   OnCancel="CloseConfirmModal"
                   OnConfirm="RunConfirmAction" />
    <section class="studio-hero">
        <nav class="studio-demo-nav">
            <a href="/" class="studio-back-link">← Back to Portfolio</a>
            <span>37 Music Studio Demo</span>
        </nav>

        <div class="studio-hero-grid">
            <div>
                <p class="studio-kicker">Interactive Web App Demo</p>
                <h1>Studio Music Management System</h1>
                <p class="studio-lead">
                    Demo aplikasi pengelolaan studio musik: booking jadwal, paket sewa,
                    status pembayaran, invoice, customer, dan dashboard owner.
                </p>

                <div class="studio-hero-actions">
                    <a href="/studio-demo#booking" class="studio-primary-btn">Coba Booking</a>
                    <a href="/studio-demo#invoice" class="studio-secondary-btn">Lihat Invoice</a>
                    <a href="/studio-admin" class="studio-secondary-btn">Buka Admin Demo</a>
                </div>
            </div>

            <div class="studio-live-card">
                <div class="studio-live-header">
                    <div>
                        <small>Today Overview</small>
                        <strong>@TodayBookings booking</strong>
                    </div>
                    <span>Live Demo</span>
                </div>

                <div class="studio-equalizer">
                    <i style="height: 45%"></i>
                    <i style="height: 70%"></i>
                    <i style="height: 38%"></i>
                    <i style="height: 88%"></i>
                    <i style="height: 62%"></i>
                    <i style="height: 95%"></i>
                    <i style="height: 54%"></i>
                    <i style="height: 76%"></i>
                </div>

                <div class="studio-live-footer">
                    <span>Projected Revenue</span>
                    <strong>@FormatRupiah(TotalRevenue)</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="studio-section">
        <div class="studio-stats-grid">
            <article class="studio-stat-card">
                <span>Total Booking</span>
                <strong>@Bookings.Count</strong>
                <p>Booking aktif bulan ini</p>
            </article>

            <article class="studio-stat-card">
                <span>Projected Revenue</span>
                <strong>@FormatRupiah(TotalRevenue)</strong>
                <p>Tidak termasuk cancelled</p>
            </article>

            <article class="studio-stat-card">
                <span>Paid Revenue</span>
                <strong>@FormatRupiah(PaidRevenue)</strong>
                <p>Booking sudah lunas</p>
            </article>

            <article class="studio-stat-card">
                <span>Pending</span>
                <strong>@PendingBookings</strong>
                <p>Menunggu pembayaran</p>
            </article>
        </div>
    </section>

    <section class="studio-section">
        <div class="studio-command-bar">
            <div>
                <p>Booking Control</p>
                <h2>Kelola Jadwal Studio</h2>
            </div>

            <div class="studio-search-wrap">
                <input @bind="SearchQuery" @bind:event="oninput" placeholder="Search customer / paket..." />
            </div>
        </div>

        <div class="studio-filter-row">
            @foreach (var filter in StatusFilters)
            {
                <button class="@GetFilterClass(filter)" @onclick="() => SetFilter(filter)">
                    @filter
                </button>
            }
        </div>
    </section>

    <section class="studio-section studio-dashboard-grid">
        <div class="studio-panel">
            <div class="studio-panel-header">
                <div>
                    <p>Booking Schedule</p>
                    <h2>Jadwal Studio</h2>
                </div>
                <span>@SelectedDate.ToString("dd MMM yyyy")</span>
            </div>

            <div class="booking-list">
                @if (!FilteredBookings.Any())
                {
                    <div class="booking-empty">
                        <strong>Booking nggak ketemu</strong>
                        <p>Coba ganti keyword atau filter statusnya.</p>
                    </div>
                }
                else
                {
                    @foreach (var booking in FilteredBookings)
                    {
                        <button class="@GetBookingClass(booking)"
                                @onclick="() => SelectBooking(booking)">
                            <div>
                                <strong>@booking.CustomerName</strong>
                                <span>@booking.PackageName • @booking.Time</span>
                            </div>

                            <em class="@GetStatusClass(booking.Status)">
                                @booking.Status
                            </em>
                        </button>
                    }
                }
            </div>
        </div>

        <div class="studio-panel selected-booking-card">
            <div class="studio-panel-header">
                <div>
                    <p>Selected Booking</p>
                    <h2>@SelectedBooking.CustomerName</h2>
                </div>
                <span class="@GetStatusClass(SelectedBooking.Status)">
                    @SelectedBooking.Status
                </span>
            </div>

            <div class="selected-booking-body">
                <div>
                    <span>Paket</span>
                    <strong>@SelectedBooking.PackageName</strong>
                </div>

                <div>
                    <span>Jam</span>
                    <strong>@SelectedBooking.Time</strong>
                </div>

                <div>
                    <span>Durasi</span>
                    <strong>@SelectedBooking.Duration jam</strong>
                </div>

                <div>
                    <span>Total</span>
                    <strong>@FormatRupiah(SelectedBooking.Price)</strong>
                </div>
            </div>

            <div class="studio-action-row">
                <button class="studio-mini-btn paid" @onclick="MarkSelectedPaid">Mark Paid</button>
                <button class="studio-mini-btn pending" @onclick="MarkSelectedPending">Set Pending</button>
                <button class="studio-mini-btn cancelled" @onclick="RequestCancelSelectedBooking">Cancel</button>
                <button class="studio-mini-btn danger" @onclick="RequestDeleteSelectedBooking">Delete</button>
            </div>

            <div class="studio-note">
                <strong>Catatan:</strong>
                @SelectedBooking.Note
            </div>

            <div class="mini-insight-grid">
                <div>
                    <span>Invoice ID</span>
                    <strong>#INV-37-@SelectedBooking.Id.ToString("000")</strong>
                </div>
                <div>
                    <span>Payment</span>
                    <strong>@SelectedBooking.Status</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="studio-section studio-dashboard-grid" id="booking">
        <div class="studio-panel">
            <div class="studio-panel-header">
                <div>
                    <p>Quick Booking</p>
                    <h2>Tambah Booking Demo</h2>
                </div>
            </div>

            <div class="booking-form">
                <label>
                    Nama Customer
                    <input @bind="NewCustomerName" placeholder="Contoh: Rama Band" />
                </label>

                <label>
                    Paket Studio
                    <select @bind="SelectedPackageId">
                        @foreach (var package in Packages)
                        {
                            <option value="@package.Id">@package.Name - @FormatRupiah(package.Price)</option>
                        }
                    </select>
                </label>

                <label>
                    Jam Booking
                    <input @bind="NewBookingTime" placeholder="Contoh: 19:00 - 21:00" />
                </label>

                <label>
                    Catatan
                    <textarea @bind="NewNote" placeholder="Contoh: Bawa drummer tambahan, butuh 2 mic"></textarea>
                </label>

                <button class="studio-primary-btn full" @onclick="AddBooking">
                    Tambah Booking
                </button>
            </div>
        </div>

        <div class="studio-panel">
            <div class="studio-panel-header">
                <div>
                    <p>Studio Packages</p>
                    <h2>Paket Sewa</h2>
                </div>
            </div>

            <div class="package-grid">
                @foreach (var package in Packages)
                {
                    <article class="package-card">
                        <span>@package.Tag</span>
                        <h3>@package.Name</h3>
                        <strong>@FormatRupiah(package.Price)</strong>
                        <p>@package.Description</p>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="studio-section print-section" id="invoice">
        <div class="studio-panel invoice-preview invoice-preview-upgraded">
            <div class="invoice-toolbar">
                <div>
                    <p>Invoice Preview</p>
                    <h2>Tagihan booking studio yang siap dicetak</h2>
                </div>

                <div class="invoice-toolbar-actions">
                    <button class="studio-secondary-btn" @onclick="CopyInvoiceSummary">
                        Copy Summary
                    </button>

                    <button class="studio-primary-btn" @onclick="PrintInvoice">
                        Print Invoice
                    </button>
                </div>
            </div>

            <div class="invoice-paper upgraded-invoice">
                <div class="invoice-brand-row">
                    <div class="invoice-brand">
                        <div class="invoice-logo">37</div>
                        <div>
                            <h2>37 Music Studio</h2>
                            <p>Studio rehearsal, recording prep, and creative music space.</p>
                        </div>
                    </div>

                    <div class="invoice-badge">
                        <span>Invoice</span>
                        <strong>#INV-37-@SelectedBooking.Id.ToString("000")</strong>
                    </div>
                </div>

                <div class="invoice-meta-grid upgraded">
                    <div>
                        <span>Bill To</span>
                        <strong>@SelectedBooking.CustomerName</strong>
                        <p>Customer / Band / Project</p>
                    </div>

                    <div>
                        <span>Invoice Date</span>
                        <strong>@SelectedDate.ToString("dd MMM yyyy")</strong>
                        <p>Generated from demo app</p>
                    </div>

                    <div>
                        <span>Status</span>
                        <strong>@SelectedBooking.Status</strong>
                        <p>@GetInvoiceStatusNote()</p>
                    </div>
                </div>

                <div class="invoice-studio-info">
                    <div>
                        <span>Studio Contact</span>
                        <strong>marsicprod@gmail.com</strong>
                        <p>Jakarta / Tangerang Area • Demo business profile</p>
                    </div>

                    <div>
                        <span>Payment Method</span>
                        <strong>Bank Transfer / Cash</strong>
                        <p>Payment instruction can be customized for real business use.</p>
                    </div>
                </div>

                <div class="invoice-service-table">
                    <div class="invoice-service-row head">
                        <span>Layanan</span>
                        <span>Waktu</span>
                        <span>Durasi</span>
                        <span>Total</span>
                    </div>

                    <div class="invoice-service-row">
                        <span>
                            <strong>@SelectedBooking.PackageName</strong>
                            <small>@SelectedBooking.Note</small>
                        </span>
                        <span>@SelectedBooking.Time</span>
                        <span>@SelectedBooking.Duration jam</span>
                        <span>@FormatRupiah(SelectedBooking.Price)</span>
                    </div>
                </div>

                <div class="invoice-summary-grid">
                    <div class="invoice-terms">
                        <h3>Terms & Notes</h3>
                        <ul>
                            <li>Booking dianggap valid setelah pembayaran DP atau konfirmasi admin.</li>
                            <li>Reschedule mengikuti ketersediaan slot studio.</li>
                            <li>Invoice ini adalah preview demo dan belum terhubung ke database.</li>
                        </ul>
                    </div>

                    <div class="invoice-total-card">
                        <div>
                            <span>Subtotal</span>
                            <strong>@FormatRupiah(InvoiceSubtotal)</strong>
                        </div>

                        <div>
                            <span>@InvoicePaidLabel</span>
                            <strong>@FormatRupiah(InvoicePaidAmount)</strong>
                        </div>

                        <div>
                            <span>Remaining</span>
                            <strong>@FormatRupiah(InvoiceRemaining)</strong>
                        </div>

                        <div class="grand">
                            <span>Grand Total</span>
                            <strong>@FormatRupiah(InvoiceSubtotal)</strong>
                        </div>
                    </div>
                </div>

                <div class="invoice-footer-upgraded">
                    <p>
                        Thank you for choosing <strong>37 Music Studio</strong>.
                        This invoice layout can be expanded into PDF export, automatic numbering,
                        payment tracking, and customer history.
                    </p>
                </div>
            </div>
        </div>
    </section>
</main>


