    private void SelectDemo(int index)
    {
        ActiveDemoIndex = index;
    }

    private string GetDemoButtonClass(int index)
    {
        return ActiveDemoIndex == index ? "demo-tab active" : "demo-tab";
    }

    private static readonly List<DemoItem> Demos =
