@page "/"
@rendermode InteractiveServer

<PageTitle>AI Web App Builder Portfolio</PageTitle>

<main class="portfolio-page">
    <section class="hero-section hero-youth" id="home">
        <div class="noise-layer"></div>
        <div class="mouse-glow"></div>
        <div class="hero-bg-orb hero-bg-orb-one"></div>
        <div class="hero-bg-orb hero-bg-orb-two"></div>
        <div class="hero-mesh"></div>

        <nav class="landing-nav nav-youth" data-aos="fade-down">
            <a class="brand" href="#home" aria-label="Back to home">
                <span class="brand-mark">M</span>
                <span class="brand-text">Marsic AI Lab</span>
            </a>

            <div class="nav-links">
                <a href="#about">Tentang</a>
                <a href="#services">Layanan</a>
                <a href="#demo">Demo</a>
                <a href="#projects">Project</a>
                <a href="#contact">Kontak</a>
            </div>
        </nav>

        <div class="hero-grid hero-youth-grid">
            <div class="hero-copy" data-aos="fade-right">
                <div class="creator-chip">
                    <span class="live-dot"></span>
                    AI-assisted digital builder • fast prototype • modern web app
                </div>

                <h1 class="hero-title-youth">
                    Bikin web app modern dengan
                    <span id="typed-role" class="typed-role">AI Web App Builder</span>
                </h1>

                <p class="hero-description hero-description-youth">
                    Gue membangun landing page, dashboard, dan prototype web app dengan bantuan AI,
                    prompt engineering, UI direction, dan workflow otomasi. Fokusnya bukan sekadar
                    generate kode, tapi mengubah ide mentah jadi produk digital yang rapi, bisa diklik,
                    dan siap dikembangkan.
                </p>

                <div class="hero-actions">
                    <a class="btn-primary btn-youth" href="/studio-demo" data-magnetic>
                        Lihat Demo App
                        <span>→</span>
                    </a>

                    <a class="btn-secondary btn-youth-outline" href="/studio-admin" data-magnetic>
                        Admin Demo
                    </a>

                    <a class="btn-secondary btn-youth-outline" href="#contact" data-magnetic>
                        Ajak Kolaborasi
                    </a>
                </div>

                <div class="tech-stack-strip" aria-label="Tech and workflow stack">
                    <span>Blazor</span>
                    <span>Prompt Engineering</span>
                    <span>UI/UX Direction</span>
                    <span>Workflow Automation</span>
                    <span>MVP Prototype</span>
                </div>

                <div class="hero-stats hero-stats-youth">
                    <div data-tilt-card>
                        <strong>01</strong>
                        <span>Ide → Prototype</span>
                    </div>
                    <div data-tilt-card>
                        <strong>AI</strong>
                        <span>Build Partner</span>
                    </div>
                    <div data-tilt-card>
                        <strong>Fast</strong>
                        <span>Iterasi Cepat</span>
                    </div>
                </div>
            </div>

            <div class="hero-showcase hero-showcase-youth" data-aos="zoom-in-left">
                <div class="creator-console" data-tilt-card>
                    <div class="console-topbar">
                        <div>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <p>marsic-ai-lab.dev</p>
                    </div>

                    <div class="console-body">
                        <div class="console-command">
                            <span>prompt://</span>
                            <p>build landing page modern untuk AI web app creator</p>
                        </div>

                        <div class="console-grid">
                            <div class="console-card big">
                                <small>Current build</small>
                                <strong>Portfolio Landing</strong>
                                <div class="progress-line">
                                    <span style="width: 88%"></span>
                                </div>
                            </div>

                            <div class="console-card">
                                <small>Vibe</small>
                                <strong>Neon Glass</strong>
                            </div>

                            <div class="console-card">
                                <small>Status</small>
                                <strong>Polished</strong>
                            </div>
                        </div>

                        <div class="mini-preview">
                            <div class="mini-sidebar">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>

                            <div class="mini-main">
                                <div class="mini-hero"></div>
                                <div class="mini-row">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                                <div class="mini-chart">
                                    <i style="height: 46%"></i>
                                    <i style="height: 78%"></i>
                                    <i style="height: 62%"></i>
                                    <i style="height: 90%"></i>
                                    <i style="height: 54%"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="floating-note note-one glass-badge">
                    <strong>Prompt</strong>
                    <span>direction</span>
                </div>

                <div class="floating-note note-two glass-badge">
                    <strong>AI</strong>
                    <span>execution</span>
                </div>

                <div class="floating-note note-three glass-badge">
                    <strong>Human</strong>
                    <span>taste</span>
                </div>
            </div>
        </div>

        <div class="marquee-panel" data-aos="fade-up">
            <div class="marquee-track">
                <span>Landing Page</span>
                <span>Dashboard UI</span>
                <span>Booking App</span>
                <span>Invoice System</span>
                <span>AI Workflow</span>
                <span>Prototype MVP</span>
                <span>Landing Page</span>
                <span>Dashboard UI</span>
                <span>Booking App</span>
                <span>Invoice System</span>
                <span>AI Workflow</span>
                <span>Prototype MVP</span>
            </div>
        </div>
    </section>

    <section class="section about-section" id="about">
        <div class="section-heading">
            <p>Tentang gue</p>
            <h2>Gue bantu mengubah ide digital jadi prototype web app yang rapi, modern, dan bisa langsung dicoba.</h2>
        </div>

        <div class="about-grid">
            <article class="glass-card about-card-large" data-aos="fade-up" data-tilt-card>
                <h3>Posisi gue</h3>
                <p>
                    Gue bekerja dengan pendekatan AI-assisted development: menyusun kebutuhan,
                    mengarahkan AI lewat prompt yang jelas, menentukan arah visual, mengetes fitur,
                    memperbaiki bug, dan memoles hasil akhirnya sampai terasa seperti produk digital
                    yang layak dipresentasikan.
                </p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">⚡</span>
                <h3>Prototype cepat</h3>
                <p>Dari ide awal jadi tampilan web app yang bisa diklik, diuji, dan dipresentasikan.</p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">🎨</span>
                <h3>Arah visual jelas</h3>
                <p>Membantu menentukan style UI, struktur halaman, komponen, warna, dan rasa brand.</p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">🤖</span>
                <h3>Workflow AI terarah</h3>
                <p>AI dipakai sebagai partner produksi: dari ide, copywriting, UI, kode, sampai iterasi.</p>
            </article>
        </div>
    </section>

    <section class="section services-section" id="services">
        <div class="section-heading compact">
            <p>Layanan</p>
            <h2>Jenis project yang bisa gue bantu bangun</h2>
        </div>

        <div class="service-grid">
            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>01</span>
                <h3>Landing Page Bisnis</h3>
                <p>Halaman promosi modern untuk jasa, UMKM, studio, personal brand, produk digital, atau campaign.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>02</span>
                <h3>Web App Prototype</h3>
                <p>Prototype aplikasi seperti booking system, invoice generator, dashboard admin, dan katalog layanan.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>03</span>
                <h3>Dashboard & Admin UI</h3>
                <p>Dashboard untuk memantau order, revenue, customer, jadwal, dan aktivitas bisnis secara visual.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>04</span>
                <h3>AI Content System</h3>
                <p>Bantu menyusun copywriting, struktur fitur, user flow, microcopy, dan narasi presentasi produk.</p>
            </article>
        </div>
    </section>

    <section class="section demo-section demo-section-polished" id="demo">
        <div class="section-heading">
            <p>Live prototype</p>
            <h2>Demo web app yang bisa langsung dicoba.</h2>
        </div>

        <div class="demo-cta-grid" data-aos="fade-up">
            <a class="demo-cta-card primary-demo" href="/studio-demo" data-tilt-card>
                <div class="demo-cta-icon">🎧</div>
                <div>
                    <span>User App Demo</span>
                    <h3>Studio Management App</h3>
                    <p>
                        Coba alur booking studio, filter jadwal, tambah booking,
                        update status pembayaran, dan preview invoice.
                    </p>
                </div>
                <strong>Buka Studio Demo →</strong>
            </a>

            <a class="demo-cta-card" href="/studio-admin" data-tilt-card>
                <div class="demo-cta-icon">⚡</div>
                <div>
                    <span>Admin Panel Demo</span>
                    <h3>Dashboard Owner</h3>
                    <p>
                        Masuk ke simulasi dashboard admin untuk melihat overview,
                        booking manager, customer, finance, dan settings.
                    </p>
                </div>
                <strong>Buka Admin Demo →</strong>
            </a>
        </div>

        <div class="demo-note-strip" data-aos="fade-up">
            <span>Demo mode</span>
            <p>
                Data masih dummy dan belum tersimpan ke database. Fokus demo ini adalah menunjukkan flow,
                tampilan, interaksi, dan arah produk yang bisa dikembangkan ke versi production.
            </p>
        </div>

        <div class="demo-shell">
            <div class="demo-tabs" role="tablist" aria-label="Demo app selector">
                @for (var i = 0; i < Demos.Count; i++)
                {
                    var index = i;
                    var demo = Demos[index];

                    <button type="button"
                            class="@GetDemoButtonClass(index)"
                            @onclick="() => SelectDemo(index)"
                            aria-pressed="@(ActiveDemoIndex == index)">
                        <span>@demo.Number</span>
                        @demo.Title
                    </button>
                }
            </div>

            <div class="demo-preview-panel">
                <div class="app-window">
                    <div class="app-window-top">
                        <div>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <p>@ActiveDemo.Url</p>
                    </div>

                    <div class="app-window-body">
                        <aside class="app-demo-sidebar">
                            <div class="demo-avatar">@ActiveDemo.Icon</div>
                            <p>@ActiveDemo.Category</p>
                            <span></span>
                            <span></span>
                            <span></span>
                        </aside>

                        <div class="app-demo-main">
                            <div class="demo-main-header">
                                <div>
                                    <p>@ActiveDemo.Label</p>
                                    <h3>@ActiveDemo.Title</h3>
                                </div>

                                <span>@ActiveDemo.Badge</span>
                            </div>

                            <p class="demo-description">@ActiveDemo.Description</p>

                            <div class="demo-metrics">
                                <div>
                                    <strong>@ActiveDemo.MetricOne</strong>
                                    <span>@ActiveDemo.MetricOneLabel</span>
                                </div>
                                <div>
                                    <strong>@ActiveDemo.MetricTwo</strong>
                                    <span>@ActiveDemo.MetricTwoLabel</span>
                                </div>
                                <div>
                                    <strong>@ActiveDemo.MetricThree</strong>
                                    <span>@ActiveDemo.MetricThreeLabel</span>
                                </div>
                            </div>

                            <div class="demo-list">
                                @foreach (var item in ActiveDemo.Features)
                                {
                                    <div>
                                        <span>✓</span>
                                        <p>@item</p>
                                    </div>
                                }
                            </div>

                            <div class="demo-preview-actions">
                                <a href="/studio-demo">Coba User App</a>
                                <a href="/studio-admin">Coba Admin Panel</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="demo-caption">
                    <strong>Catatan:</strong>
                    preview di bawah ini menjelaskan konsep fitur. Untuk pengalaman interaktif penuh,
                    buka Studio Demo atau Admin Panel Demo.
                </div>
            </div>
        </div>
    </section>

    <section class="section projects-section" id="projects">
        <div class="section-heading compact">
            <p>Featured build</p>
            <h2>Prototype yang sudah disiapkan untuk portfolio</h2>
        </div>

        <div class="project-grid">
            <article class="project-card featured-project" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Featured</span>
                    <span>Blazor Web App</span>
                </div>
                <h3>Studio Music Management App</h3>
                <p>
                    Prototype aplikasi manajemen studio musik dengan booking, invoice,
                    status pembayaran, data customer, paket sewa, dan dashboard admin.
                </p>
                <a href="/studio-demo">Buka demo interaktif →</a>
            </article>

            <article class="project-card" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Prototype</span>
                    <span>Invoice</span>
                </div>
                <h3>Digital Invoice Generator</h3>
                <p>Generate invoice modern untuk jasa, rental, studio, dan UMKM.</p>
            </article>

            <article class="project-card" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Dashboard</span>
                    <span>Admin UI</span>
                </div>
                <h3>Business Control Panel</h3>
                <p>Panel visual untuk memantau order, revenue, customer, dan aktivitas harian.</p>
            </article>
        </div>
    </section>

    <section class="section process-section">
        <div class="section-heading compact">
            <p>Workflow</p>
            <h2>Workflow kerja dari ide sampai prototype</h2>
        </div>

        <div class="timeline">
            <div class="timeline-item" data-aos="fade-up">
                <span>1</span>
                <div>
                    <h3>Brief & arah produk</h3>
                    <p>Kita susun tujuan, target user, fitur utama, konten, dan vibe visual project.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>2</span>
                <div>
                    <h3>Prompt & struktur</h3>
                    <p>Kebutuhan project dipecah jadi prompt, struktur halaman, komponen, dan flow aplikasi.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>3</span>
                <div>
                    <h3>Build, test, polish</h3>
                    <p>Kode dibuat, tampilan diuji, bug dibenerin, responsive dirapikan, dan UI dipoles.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>4</span>
                <div>
                    <h3>Siap dipresentasikan</h3>
                    <p>Project disiapkan agar layak dipamerkan, dipakai demo, atau dikembangkan ke versi production.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contact">
        <div>
            <p>Siap bikin project?</p>
            <h2>Punya ide website atau web app? Kita bisa ubah jadi prototype modern yang siap dipresentasikan.</h2>
        </div>

        <div class="contact-actions">
            <a class="btn-primary" href="mailto:marsicprod@gmail.com">
                Email Gue
                <span>→</span>
            </a>

            <a class="btn-secondary light" href="https://github.com/jangangitungapah-pixel/Portofoliowebapp" target="_blank" rel="noopener noreferrer">
                Lihat GitHub
            </a>
        </div>
    </section>
</main>

@code {
    private int ActiveDemoIndex { get; set; }

    private DemoItem ActiveDemo => Demos[ActiveDemoIndex];

    private void SelectDemo(int index)
    {
        ActiveDemoIndex = index;
    }

    private string GetDemoButtonClass(int index)
    {
        return ActiveDemoIndex == index ? "demo-tab active" : "demo-tab";
    }

    private static readonly List<DemoItem> Demos =
    [
        new(
