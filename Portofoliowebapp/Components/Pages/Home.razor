@page "/"
@rendermode InteractiveServer

<PageTitle>AI Web App Builder Portfolio</PageTitle>

<main class="portfolio-page">
    <section class="hero-section hero-youth" id="home">
        <div class="noise-layer"></div>
        <div class="mouse-glow"></div>
        <div class="hero-bg-orb hero-bg-orb-one"></div>
        <div class="hero-bg-orb hero-bg-orb-two"></div>
        <div class="hero-mesh"></div>

        <nav class="landing-nav nav-youth" data-aos="fade-down">
            <a class="brand" href="#home" aria-label="Back to home">
                <span class="brand-mark">M</span>
                <span class="brand-text">Marsic AI Lab</span>
            </a>

            <div class="nav-links">
                <a href="#about">Tentang</a>
                <a href="#services">Layanan</a>
                <a href="#demo">Demo</a>
                <a href="#projects">Project</a>
                <a href="#contact">Kontak</a>
            </div>
        </nav>

        <div class="hero-grid hero-youth-grid">
            <div class="hero-copy" data-aos="fade-right">
                <div class="creator-chip">
                    <span class="live-dot"></span>
                    Portfolio mode: AI builder, bukan coder template-an
                </div>

                <h1 class="hero-title-youth">
                    Gue bikin web app dengan
                    <span id="typed-role" class="typed-role">AI Web App Builder</span>
                </h1>

                <p class="hero-description hero-description-youth">
                    Gue orang awam yang suka banget ngebangun website dan web app pakai AI.
                    Fokus gue ada di prompt direction, UI taste, workflow automation, testing,
                    dan nge-polish hasil AI sampai kelihatan kayak produk digital beneran.
                </p>

                <div class="hero-actions">
                    <a class="btn-primary btn-youth" href="/studio-demo" data-magnetic>
                        Lihat Demo App
                        <span>→</span>
                    </a>

                    <a class="btn-secondary btn-youth-outline" href="/studio-admin" data-magnetic>
                        Admin Demo
                    </a>

                    <a class="btn-secondary btn-youth-outline" href="#contact" data-magnetic>
                        Ajak Kolaborasi
                    </a>
                </div>

                <div class="tech-stack-strip" aria-label="Tech and workflow stack">
                    <span>Blazor</span>
                    <span>AI Prompting</span>
                    <span>UI Direction</span>
                    <span>Automation</span>
                    <span>Prototype</span>
                </div>

                <div class="hero-stats hero-stats-youth">
                    <div data-tilt-card>
                        <strong>01</strong>
                        <span>Ide → Prototype</span>
                    </div>
                    <div data-tilt-card>
                        <strong>AI</strong>
                        <span>Build Partner</span>
                    </div>
                    <div data-tilt-card>
                        <strong>Fast</strong>
                        <span>Iterasi Cepat</span>
                    </div>
                </div>
            </div>

            <div class="hero-showcase hero-showcase-youth" data-aos="zoom-in-left">
                <div class="creator-console" data-tilt-card>
                    <div class="console-topbar">
                        <div>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <p>marsic-ai-lab.dev</p>
                    </div>

                    <div class="console-body">
                        <div class="console-command">
                            <span>prompt://</span>
                            <p>build landing page modern untuk AI web app creator</p>
                        </div>

                        <div class="console-grid">
                            <div class="console-card big">
                                <small>Current build</small>
                                <strong>Portfolio Landing</strong>
                                <div class="progress-line">
                                    <span style="width: 88%"></span>
                                </div>
                            </div>

                            <div class="console-card">
                                <small>Vibe</small>
                                <strong>Neon Glass</strong>
                            </div>

                            <div class="console-card">
                                <small>Status</small>
                                <strong>Polished</strong>
                            </div>
                        </div>

                        <div class="mini-preview">
                            <div class="mini-sidebar">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>

                            <div class="mini-main">
                                <div class="mini-hero"></div>
                                <div class="mini-row">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                                <div class="mini-chart">
                                    <i style="height: 46%"></i>
                                    <i style="height: 78%"></i>
                                    <i style="height: 62%"></i>
                                    <i style="height: 90%"></i>
                                    <i style="height: 54%"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="floating-note note-one glass-badge">
                    <strong>Prompt</strong>
                    <span>direction</span>
                </div>

                <div class="floating-note note-two glass-badge">
                    <strong>AI</strong>
                    <span>execution</span>
                </div>

                <div class="floating-note note-three glass-badge">
                    <strong>Human</strong>
                    <span>taste</span>
                </div>
            </div>
        </div>

        <div class="marquee-panel" data-aos="fade-up">
            <div class="marquee-track">
                <span>Landing Page</span>
                <span>Dashboard UI</span>
                <span>Booking App</span>
                <span>Invoice System</span>
                <span>AI Workflow</span>
                <span>Prototype MVP</span>
                <span>Landing Page</span>
                <span>Dashboard UI</span>
                <span>Booking App</span>
                <span>Invoice System</span>
                <span>AI Workflow</span>
                <span>Prototype MVP</span>
            </div>
        </div>
    </section>

    <section class="section about-section" id="about">
        <div class="section-heading">
            <p>Tentang gue</p>
            <h2>Bukan cuma “generate code”, tapi ngarahin AI sampai jadi produk yang enak dipakai.</h2>
        </div>

        <div class="about-grid">
            <article class="glass-card about-card-large" data-aos="fade-up" data-tilt-card>
                <h3>Posisi gue</h3>
                <p>
                    Gue orang awam yang belajar bikin web app lewat AI. Kekuatan gue ada di cara
                    menyusun kebutuhan, bikin prompt yang jelas, mengarahkan style UI, mencoba fitur,
                    memperbaiki bug, dan merapikan hasilnya supaya terasa seperti produk beneran.
                </p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">⚡</span>
                <h3>Cepat bikin prototype</h3>
                <p>Dari ide mentah jadi tampilan awal yang bisa dicoba, dipresentasikan, dan dikembangkan.</p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">🎨</span>
                <h3>Visual direction</h3>
                <p>Landing page, dashboard, invoice, company profile, dan UI modern dengan rasa brand yang kuat.</p>
            </article>

            <article class="glass-card" data-aos="fade-up" data-tilt-card>
                <span class="card-icon">🤖</span>
                <h3>AI workflow</h3>
                <p>Menggunakan AI untuk generate, refactor, bikin konten, bantu desain, dan mempercepat produksi.</p>
            </article>
        </div>
    </section>

    <section class="section services-section" id="services">
        <div class="section-heading compact">
            <p>Layanan</p>
            <h2>Yang bisa gue bantu bikin</h2>
        </div>

        <div class="service-grid">
            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>01</span>
                <h3>Landing Page Bisnis</h3>
                <p>Halaman promosi modern untuk jasa, studio, UMKM, personal brand, event, atau produk digital.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>02</span>
                <h3>Web App Prototype</h3>
                <p>Prototype aplikasi seperti booking studio, invoice generator, dashboard admin, dan katalog layanan.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>03</span>
                <h3>Dashboard & Admin UI</h3>
                <p>Tampilan panel manajemen data yang rapi, informatif, dan mudah dipahami oleh user non-teknis.</p>
            </article>

            <article class="service-card" data-aos="fade-up" data-tilt-card>
                <span>04</span>
                <h3>AI Content System</h3>
                <p>Bantu susun copywriting, struktur halaman, nama fitur, flow aplikasi, dan presentasi produk.</p>
            </article>
        </div>
    </section>

    <section class="section demo-section" id="demo">
        <div class="section-heading">
            <p>Demo web app</p>
            <h2>Contoh mini app yang bisa masuk ke landing page ini.</h2>
        </div>

        <div class="demo-shell">
            <div class="demo-tabs" role="tablist" aria-label="Demo app selector">
                @for (var i = 0; i < Demos.Count; i++)
                {
                    var index = i;
                    var demo = Demos[index];

                    <button type="button"
                            class="@GetDemoButtonClass(index)"
                            @onclick="() => SelectDemo(index)"
                            aria-pressed="@(ActiveDemoIndex == index)">
                        <span>@demo.Number</span>
                        @demo.Title
                    </button>
                }
            </div>

            <div class="demo-preview-panel">
                <div class="app-window">
                    <div class="app-window-top">
                        <div>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <p>@ActiveDemo.Url</p>
                    </div>

                    <div class="app-window-body">
                        <aside class="app-demo-sidebar">
                            <div class="demo-avatar">@ActiveDemo.Icon</div>
                            <p>@ActiveDemo.Category</p>
                            <span></span>
                            <span></span>
                            <span></span>
                        </aside>

                        <div class="app-demo-main">
                            <div class="demo-main-header">
                                <div>
                                    <p>@ActiveDemo.Label</p>
                                    <h3>@ActiveDemo.Title</h3>
                                </div>

                                <span>@ActiveDemo.Badge</span>
                            </div>

                            <p class="demo-description">@ActiveDemo.Description</p>

                            <div class="demo-metrics">
                                <div>
                                    <strong>@ActiveDemo.MetricOne</strong>
                                    <span>@ActiveDemo.MetricOneLabel</span>
                                </div>
                                <div>
                                    <strong>@ActiveDemo.MetricTwo</strong>
                                    <span>@ActiveDemo.MetricTwoLabel</span>
                                </div>
                                <div>
                                    <strong>@ActiveDemo.MetricThree</strong>
                                    <span>@ActiveDemo.MetricThreeLabel</span>
                                </div>
                            </div>

                            <div class="demo-list">
                                @foreach (var item in ActiveDemo.Features)
                                {
                                    <div>
                                        <span>✓</span>
                                        <p>@item</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="demo-caption">
                    <strong>Catatan:</strong>
                    ini masih mockup interaktif di landing page. Nanti bisa dikembangkan jadi app beneran
                    dengan database, login, dan dashboard admin.
                </div>
            </div>
        </div>
    </section>

    <section class="section projects-section" id="projects">
        <div class="section-heading compact">
            <p>Project ideas</p>
            <h2>Konsep project yang bisa dipamerkan</h2>
        </div>

        <div class="project-grid">
            <article class="project-card featured-project" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Featured</span>
                    <span>Blazor Web App</span>
                </div>
                <h3>Studio Music Management App</h3>
                <p>
                    Sistem booking studio musik dengan jadwal, invoice, status pembayaran,
                    data pelanggan, paket sewa, dan dashboard owner.
                </p>
                <a href="/studio-demo">Buka demo interaktif →</a>
            </article>

            <article class="project-card" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Prototype</span>
                    <span>Invoice</span>
                </div>
                <h3>Digital Invoice Generator</h3>
                <p>Generate invoice modern untuk jasa, rental, studio, dan UMKM.</p>
            </article>

            <article class="project-card" data-aos="fade-up" data-tilt-card>
                <div class="project-meta">
                    <span>Dashboard</span>
                    <span>Admin UI</span>
                </div>
                <h3>Business Control Panel</h3>
                <p>Panel visual untuk memantau order, revenue, customer, dan aktivitas harian.</p>
            </article>
        </div>
    </section>

    <section class="section process-section">
        <div class="section-heading compact">
            <p>Workflow</p>
            <h2>Cara gue ngerjain project</h2>
        </div>

        <div class="timeline">
            <div class="timeline-item" data-aos="fade-up">
                <span>1</span>
                <div>
                    <h3>Brief & ide</h3>
                    <p>Kita susun tujuan website, target user, fitur utama, dan vibe visualnya.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>2</span>
                <div>
                    <h3>AI prompt direction</h3>
                    <p>Gue pecah kebutuhan jadi prompt yang jelas untuk layout, komponen, copywriting, dan logic.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>3</span>
                <div>
                    <h3>Build & polish</h3>
                    <p>Generate kode, test tampilan, benerin bug, rapihin responsive, dan bikin lebih premium.</p>
                </div>
            </div>

            <div class="timeline-item" data-aos="fade-up">
                <span>4</span>
                <div>
                    <h3>Deploy-ready</h3>
                    <p>Siapkan project agar siap dipublish, dipresentasikan, atau dikembangkan lagi.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section" id="contact">
        <div>
            <p>Siap bikin project?</p>
            <h2>Yuk bikin web app yang keliatan mahal, walau mulai dari ide sederhana.</h2>
        </div>

        <div class="contact-actions">
            <a class="btn-primary" href="mailto:marsicprod@gmail.com">
                Email Gue
                <span>→</span>
            </a>

            <a class="btn-secondary light" href="https://github.com/jangangitungapah-pixel/Portofoliowebapp" target="_blank" rel="noopener noreferrer">
                Lihat GitHub
            </a>
        </div>
    </section>
</main>

